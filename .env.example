# Crescendo Jailbreak Generator — Environment Variables
# Copy this file to .env and fill in your values.

# OpenAI API key (used for both simulator and target if not overridden in UI)
OPENAI_API_KEY=

# Anthropic API key (optional, for Claude models)
ANTHROPIC_API_KEY=

# Together AI API key (optional, for Together-hosted open models)
TOGETHER_API_KEY=

# Application settings
DEBUG=false
HOST=0.0.0.0
PORT=8000
